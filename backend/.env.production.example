# ── PythonAnywhere Production .env ──────────────────────────────────────────
# Copy this file to .env on PythonAnywhere and fill in your real values.
# DO NOT commit .env to git.

# Django
SECRET_KEY=replace-with-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=yourusername.pythonanywhere.com

# MySQL (get these from PythonAnywhere → Databases tab)
DB_NAME=yourusername$bookleaf
DB_USER=yourusername
DB_PASSWORD=your-pythonanywhere-mysql-password
DB_HOST=yourusername.mysql.pythonanywhere-services.com
DB_PORT=3306

# CORS — set this to your Vercel URL once deployed
CORS_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Gemini
GEMINI_API_KEY=AIzaSyDgGpWCIBIiD5-8iV-ZHC2AT_b_qUC5GMo
