# ── Railway Production .env ──────────────────────────────────────────────────
# Copy this as reference for what env vars to set in Railway dashboard.
# DO NOT commit your actual .env to git.

# Django
SECRET_KEY=replace-with-a-long-random-string-50-chars
DEBUG=False

# Railway auto-injects these from the MySQL service — no need to set manually:
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE

# CORS — set this to your Vercel URL
CORS_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# Groq AI (free — get key from console.groq.com)
GROQ_API_KEY=your-groq-api-key-here
